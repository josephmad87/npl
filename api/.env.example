# Copy to .env and adjust. Paths are relative to the api/ directory.

# Local Postgres. On Heroku, Heroku Postgres sets DATABASE_URL automatically (postgres:// is normalized in app).
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/npl
# Local file DB example:
# DATABASE_URL=sqlite+pysqlite:///./npl.db

SECRET_KEY=replace-with-openssl-rand-hex-32

# Browser origins allowed for credentialed requests (admin SPA, etc.). Comma-separated.
# Required in production / Heroku (set Heroku config vars), e.g. your admin site origin.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Optional on Heroku: absolute URLs for uploaded media (defaults to request host if unset).
# PUBLIC_BASE_URL=https://your-app.herokuapp.com

# Supabase Storage (optional, recommended on Heroku for persistent media):
# If all three are set, uploads are sent to Supabase instead of local disk.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_STORAGE_BUCKET=npl-media
# Optional path prefix inside bucket:
# SUPABASE_STORAGE_PREFIX=uploads

# Optional: first-run dev seed (scripts/seed_dev.py) — only runs when users table is empty
SEED_ADMIN_EMAIL=dev@npl.local
SEED_ADMIN_PASSWORD=changeme
