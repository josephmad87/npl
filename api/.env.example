# Copy to .env and adjust. Paths are relative to the api/ directory.

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/npl
# Local file DB example:
# DATABASE_URL=sqlite+pysqlite:///./npl.db

SECRET_KEY=replace-with-openssl-rand-hex-32

# Browser origins allowed for credentialed requests (admin SPA, etc.). Comma-separated.
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: first-run dev seed (scripts/seed_dev.py) — only runs when users table is empty
SEED_ADMIN_EMAIL=dev@npl.local
SEED_ADMIN_PASSWORD=changeme
